{
  "manifest_version": 3,
  "name": "CV Extractor — Job Post to JSON",
  "version": "1.1.0",
  "description": "Extract job posts from LinkedIn, Glassdoor, Indeed, Welcome to the Jungle and more — outputs clean JSON ready for AI CV generation.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
